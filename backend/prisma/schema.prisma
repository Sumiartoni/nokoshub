generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  telegramId   String        @unique
  username     String?
  firstName    String?
  lastName     String?
  balance      Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orders       Order[]
  transactions Transaction[]
  invoices     Invoice[]
  webUsers     WebUser[]
}

model WebUser {
  id                       String                @id @default(cuid())
  email                    String                @unique
  passwordHash             String?
  googleId                 String?               @unique
  firstName                String?
  lastName                 String?
  telegramId               String?               @unique
  referralCode             String                @unique
  referredById             String?
  referredBy               WebUser?              @relation("WebUserReferrals", fields: [referredById], references: [id])
  referrals                WebUser[]             @relation("WebUserReferrals")
  referredDepositQualifiedAt DateTime?
  referralRewardGrantedAt  DateTime?
  referralRewardAmount     Int                   @default(0)
  telegramUser             User?                 @relation(fields: [telegramId], references: [telegramId])
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  linkCodes                WebTelegramLinkCode[]
  pendingReferralRegistrations PendingWebRegistration[] @relation("PendingRegistrationReferrer")

  @@index([referredById])
}

model PendingWebRegistration {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String?
  googleId         String?
  firstName        String?
  lastName         String?
  referredById     String?
  referredBy       WebUser? @relation("PendingRegistrationReferrer", fields: [referredById], references: [id])
  referralCodeUsed String?
  otpHash          String
  otpExpiresAt     DateTime
  otpAttempts      Int      @default(0)
  otpSentAt        DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([otpExpiresAt])
  @@index([referredById])
}

model WebTelegramLinkCode {
  id         String    @id @default(cuid())
  webUser    WebUser   @relation(fields: [webUserId], references: [id], onDelete: Cascade)
  webUserId  String
  code       String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([webUserId])
  @@index([expiresAt])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  serviceCode String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  prices      Price[]
}

model Country {
  id          String   @id @default(cuid())
  name        String
  countryCode String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  prices      Price[]
}

model Price {
  id            String   @id @default(cuid())
  service       Service  @relation(fields: [serviceId], references: [id])
  serviceId     String
  country       Country  @relation(fields: [countryId], references: [id])
  countryId     String
  priceId       String   @unique // provider's price_id
  providerPrice Int // in IDR
  providerPriceUsd Decimal? @db.Decimal(12, 6)
  sellPrice     Int // providerPrice x configured multiplier
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]

  @@index([serviceId, countryId])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Order {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String
  price           Price    @relation(fields: [priceId], references: [id])
  priceId         String
  providerOrderId String?
  phoneNumber     String?
  otpCode         String?
  status          String   @default("PENDING") // PENDING | ACTIVE | SUCCESS | FAILED | CANCELLED
  failReason      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([providerOrderId])
  @@index([status])
}

model Transaction {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  type        String // DEPOSIT | DEDUCT | REFUND | REFERRAL
  amount      Int
  description String?
  reference   String? // orderId or invoiceId
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Invoice {
  id                 String   @id @default(cuid())
  user               User     @relation(fields: [userId], references: [id])
  userId             String
  amount             Int
  baseAmount         Int      @default(0)
  gatewayFee         Int      @default(0)
  provider           String   @default("MANUAL_QRIS")
  paymentMethod      String?
  gatewayOrderId     String?  @unique
  paymentUrl         String?  @db.Text
  gatewayPayload     String?  @db.Text
  qrisPayload        String   @db.Text
  status             String   @default("PENDING") // PENDING | PAID | EXPIRED
  paidAt             DateTime?
  gatewayCompletedAt DateTime?
  expiredAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([status])
}
