# Application
COMPOSE_PROJECT_NAME=backend
NODE_ENV=production
API_PORT=3000
BACKOFFICE_PORT=8080
API_BASE_URL=http://backend:3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# HeroSMS Provider
HERO_SMS_API_KEY=your_hero_sms_api_key_here
HERO_SMS_BASE_URL=https://hero-sms.com/stubs/handler_api.php
HERO_SMS_PRICE_TO_IDR_RATE=17000

# QRIS Payment
QRIS_STATIC_STRING="00020101021126570011ID.DANA.WWW011893600915377384905402097738490540303UMI51440014ID.CO.QRIS.WWW0215ID10254163573130303UMI5204654053033605802ID5908NokosHub6011Kota Bekasi610517141630498AF"
QRIS_DYNAMIC_ENABLED=true
PAYMENT_WEBHOOK_SECRET=your_webhook_secret_here

# Admin and Backoffice
ADMIN_API_KEY=your_admin_api_key_here
BACKOFFICE_USERNAME=admin
BACKOFFICE_PASSWORD_HASH=
BACKOFFICE_SESSION_SECRET=generate_a_long_random_secret_here
BACKOFFICE_SESSION_HOURS=8
BACKOFFICE_COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Pricing and Worker
SELL_PRICE_MULTIPLIER=3.5
OTP_POLL_INTERVAL_MS=5000
OTP_POLL_MAX_MS=120000
