# Application
COMPOSE_PROJECT_NAME=backend
NODE_ENV=production
API_PORT=3000
FRONTEND_PORT=8081
BACKOFFICE_PORT=8080
API_BASE_URL=http://backend:3000
BACKEND_DASHBOARD_ENABLED=false
INTERNAL_API_SECRET=generate_a_long_internal_secret_here_min_24_chars
DATABASE_URL=postgresql://postgres.project_ref:your_password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require&use_libpq_compat=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_SSL_CA_B64=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_IDS=123456789
TELEGRAM_SUPPORT_HANDLE=@nokoshubsupport
TELEGRAM_MAINTENANCE_NOTICE=Maintenance harian 23:00 WIB - 00:10 WIB. Hindari transaksi pada jam tersebut karena pesanan bisa tertunda atau gagal.

# HeroSMS Provider
HERO_SMS_API_KEY=your_hero_sms_api_key_here
HERO_SMS_BASE_URL=https://hero-sms.com/stubs/handler_api.php
SMSBOWER_API_KEY=
SMSBOWER_BASE_URL=https://smsbower.page/stubs/handler_api.php
HERO_SMS_PRICE_TO_IDR_RATE=17000
USD_IDR_RATE_AUTO_ENABLED=true
USD_IDR_RATE_API_URL=https://api.frankfurter.dev/v2/rate/USD/IDR
USD_IDR_RATE_BUFFER_PERCENT=3
USD_IDR_RATE_REFRESH_MINUTES=360

# BAYAR GG Payment Gateway
PUBLIC_API_BASE_URL=https://api.nokoshub.store
BAYAR_GG_API_KEY=
BAYAR_GG_WEBHOOK_SECRET=
BAYAR_GG_PAYMENT_METHOD=qris
BAYAR_GG_REDIRECT_URL=https://nokoshub.store/#/transactions

# Legacy manual QRIS webhook (opsional, hanya untuk fallback lama)
QRIS_STATIC_STRING=
QRIS_DYNAMIC_ENABLED=true
PAYMENT_WEBHOOK_SECRET=

# Admin and Backoffice
ADMIN_API_KEY=your_admin_api_key_here
BACKOFFICE_USERNAME=admin
BACKOFFICE_PASSWORD_HASH=
BACKOFFICE_SESSION_SECRET=generate_a_long_random_secret_here
BACKOFFICE_SESSION_HOURS=8
BACKOFFICE_COOKIE_SECURE=true
CORS_ALLOWED_ORIGINS=

# Google Sign-In
# Isi dengan OAuth 2.0 Web Client ID dari Google Cloud Console.
GOOGLE_CLIENT_ID=

# Cloudflare Turnstile (opsional, direkomendasikan untuk halaman register)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email OTP
# Jika diisi, backend akan memprioritaskan konfigurasi email dari .env
# di atas panel super admin.
EMAIL_TRANSPORT=
EMAIL_FROM_NAME=NokosHUB
EMAIL_FROM_EMAIL=no-reply@nokoshub.store
BREVO_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# Pricing and Worker
SELL_PRICE_MULTIPLIER=3.5
OTP_POLL_INTERVAL_MS=5000
OTP_POLL_MAX_MS=1200000
